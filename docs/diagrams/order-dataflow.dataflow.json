{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Game4r.store — Order Placement",
    "subtitle": "From cart to confirmed order",
    "output": "order-dataflow.html",
    "quality_profile": "standard",
    "visual_preset": "classic",
    "viewBox": [940, 500]
